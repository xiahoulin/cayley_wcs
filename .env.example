CAYLEYWCS_DB_NAME=cayleywcs
CAYLEYWCS_DB_USER=cayley
CAYLEYWCS_DB_PASSWORD=cayley

# Host-published DB / Redis ports (avoid clashing with CayleyWMS 5432/6379).
CAYLEYWCS_DB_PORT=5433
CAYLEYWCS_REDIS_PORT=6380

# Backend port published on host, e.g. http://127.0.0.1:20021
CAYLEYWCS_BACKEND_PORT=20021
# Spring Boot port inside backend container.
CAYLEYWCS_BACKEND_INTERNAL_PORT=20021

# Frontend Nginx port published on host (filled in at M6).
CAYLEYWCS_FRONTEND_PORT=5184

# CORS allowed origin patterns.
CAYLEYWCS_ALLOWED_ORIGIN_PATTERNS=http://127.0.0.1:*,http://localhost:*

# Connection governance (req 4).
CAYLEYWCS_MAX_CONNECTIONS=32
CAYLEYWCS_CONNECT_TIMEOUT_SECONDS=60

# Replace in production.
CAYLEYWCS_JWT_SECRET=local-cayleywcs-development-secret-change-me
